{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=interview_prep;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Authority": "https://your-identity-provider.example.com",
    "Audience": "interview-prep-api",
    "RequiredScopes": [
      "api.read"
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://127.0.0.1:4200"
    ]
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
